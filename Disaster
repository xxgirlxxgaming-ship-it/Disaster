        TeleportTab:CreateSection("Teleport Modes")

        RFControls.Teleport.Mode = TeleportTab:CreateDropdown({
            Name = "Mode",
            Options = {"To Player", "To Lobby Position", "Smooth To Player"},
            CurrentOption = "To Player",
            Callback = function(opt)
                if opt == "To Player" then
                    TP.Mode = "ToPlayer"
                elseif opt == "To Lobby Position" then
                    TP.Mode = "ToLobby"
                else
                    TP.Mode = "Smooth"
                end
                playSound("12221967")
            end
        })

        RFControls.Teleport.TargetLabel = TeleportTab:CreateParagraph({
            Title = "Target",
            Content = "None selected"
        })

        RFControls.Teleport.PlayerDropdown = TeleportTab:CreateDropdown({
            Name = "Select Player",
            Options = {},
            CurrentOption = "None",
            Callback = function(name)
                local plr = Services.Players:FindFirstChild(name)
                if not plr then return end

                TP.Target = plr
                RFControls.Teleport.TargetLabel:Set("Target: " .. plr.Name)

                if TP.Mode == "ToLobby" and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                    TP.LobbyCFrame = plr.Character.HumanoidRootPart.CFrame
                end
                playSound("12221967")
            end
        })

        local function refreshTPDropdown()
            if not RFControls.Teleport.PlayerDropdown then return end
            if RFControls.Teleport.PlayerDropdown.Clear then
                RFControls.Teleport.PlayerDropdown:Clear()
            end
            local names = {}
            for _, plr in ipairs(Services.Players:GetPlayers()) do
                if plr ~= LocalPlayer then
                    table.insert(names, plr.Name)
                end
            end
            for _, n in ipairs(names) do
                RFControls.Teleport.PlayerDropdown:Add(n)
            end
        end

        refreshTPDropdown()

        Services.Players.PlayerAdded:Connect(function(plr)
            if plr ~= LocalPlayer and RFControls.Teleport.PlayerDropdown then
                RFControls.Teleport.PlayerDropdown:Add(plr.Name)
            end
        end)

        Services.Players.PlayerRemoving:Connect(function(plr)
            if RFControls.Teleport.PlayerDropdown then
                pcall(function()
                    RFControls.Teleport.PlayerDropdown:Remove(plr.Name)
                end)
            end
        end)

        TeleportTab:CreateSlider({
            Name = "Safe Radius (behind)",
            Range = {1, 10},
            Increment = 1,
            CurrentValue = TP.SafeRadius,
            Callback = function(v)
                TP.SafeRadius = v
                playSound("12221967")
            end
        })

        TeleportTab:CreateSlider({
            Name = "Side Offset",
            Range = {0, 10},
            Increment = 0.5,
            CurrentValue = TP.SideOffset,
            Callback = function(v)
                TP.SideOffset = v
                playSound("12221967")
            end
        })

        TeleportTab:CreateToggle({
            Name = "Auto-Follow Target",
            CurrentValue = false,
            Callback = function(v)
                TP.AutoFollow = v
                if not v then TP.Orbit = false end
                playSound("12221967")
            end
        })

        TeleportTab:CreateToggle({
            Name = "Orbit Target",
            CurrentValue = false,
            Callback = function(v)
                if not TP.AutoFollow then
                    playSound("12221967")
                    return
                end
                TP.Orbit = v
                playSound("12221967")
            end
        })

        TeleportTab:CreateToggle({
            Name = "Stay Above Target",
            CurrentValue = false,
            Callback = function(v)
                TP.StayAbove = v
                playSound("12221967")
            end
        })

        TeleportTab:CreateButton({
            Name = "Teleport to Target",
            Callback = function()
                teleportToTarget()
            end
        })

        TeleportTab:CreateButton({
            Name = "Teleport Once More",
            Callback = function()
                if TP.Target then
                    teleportToTarget()
                else
                    notify("Teleport", "No previous target.")
                end
            end
        })

        TeleportTab:CreateButton({
            Name = "Teleport to Random Player",
            Callback = function()
                randomTeleport()
            end
        })

        ---------------------------------------------------------------------
        -- RAYFIELD UI: MISC TAB
        ---------------------------------------------------------------------

        MiscTab:CreateSection("Misc Features")

        MiscTab:CreateToggle({
            Name = "Invisibility",
            CurrentValue = false,
            Callback = function(v)
                MiscState.Invis = v
                setInvisibility(v)
                playSound("12221967")
            end
        })

        MiscTab:CreateToggle({
            Name = "FPS Booster",
            CurrentValue = false,
            Callback = function(v)
                MiscState.FPSBoost = v
                if v then enableFPSBoost() else disableFPSBoost() end
                playSound("12221967")
            end
        })

        MiscTab:CreateToggle({
            Name = "Freeze Position",
            CurrentValue = false,
            Callback = function(v)
                MiscState.Freeze = v
                if v then
                    local r = getRoot()
                    if r then MiscState.FrozenCF = r.CFrame end
                end
                playSound("12221967")
            end
        })

        ---------------------------------------------------------------------
        -- RAYFIELD UI: ESP TAB (fixed)
        ---------------------------------------------------------------------

        ESPTab:CreateSection("ESP")

        RFControls.ESP.Master = ESPTab:CreateToggle({
            Name = "Master ESP",
            CurrentValue = false,
            Callback = function(v)
                MiscState.ESP = v
                playSound("12221967")
                refreshESP()
            end
        })

        ESPTab:CreateToggle({
            Name = "ESP Box",
            CurrentValue = false,
            Callback = function(v)
                MiscState.ESPBox = v
                playSound("12221967")
            end
        })

        ESPTab:CreateToggle({
            Name = "ESP Health",
            CurrentValue = false,
            Callback = function(v)
                MiscState.ESPHealth = v
                playSound("12221967")
            end
        })

        ESPTab:CreateToggle({
            Name = "ESP Name & Distance",
            CurrentValue = false,
            Callback = function(v)
                MiscState.ESPNameDist = v
                playSound("12221967")
            end
        })

        ESPTab:CreateToggle({
            Name = "Use Team Color",
            CurrentValue = false,
            Callback = function(v)
                MiscState.ESPTeamColor = v
                playSound("12221967")
            end
        })

        ESPTab:CreateToggle({
            Name = "ESP Tracers",
            CurrentValue = false,
            Callback = function(v)
                MiscState.ESPTracers = v
                playSound("12221967")
            end
        })

        ---------------------------------------------------------------------
        -- RAYFIELD UI: KEYBINDS TAB (keys visible)
        ---------------------------------------------------------------------

        KeybindTab:CreateSection("Keybinds")

        KeybindTab:CreateKeybind({
            Name = "Toggle Ring Parts (" .. keybinds.RingParts.Name .. ")",
            CurrentKeybind = keybinds.RingParts,
            HoldToInteract = false,
            Callback = function()
                toggleRing()
            end
        })

        KeybindTab:CreateKeybind({
            Name = "Toggle Flight (" .. keybinds.Flight.Name .. ")",
            CurrentKeybind = keybinds.Flight,
            HoldToInteract = false,
            Callback = function()
                if Movement.Flying then stopFlight() else startFlight() end
            end
        })

        KeybindTab:CreateKeybind({
            Name = "Toggle Godmode (" .. keybinds.Godmode.Name .. ")",
            CurrentKeybind = keybinds.Godmode,
            HoldToInteract = false,
            Callback = function()
                toggleGod()
            end
        })

        KeybindTab:CreateKeybind({
            Name = "Toggle Noclip (" .. keybinds.Noclip.Name .. ")",
            CurrentKeybind = keybinds.Noclip,
            HoldToInteract = false,
            Callback = function()
                toggleNoclip()
            end
        })

        KeybindTab:CreateKeybind({
            Name = "Teleport to Target (" .. keybinds.Teleport.Name .. ")",
            CurrentKeybind = keybinds.Teleport,
            HoldToInteract = false,
            Callback = function()
                teleportToTarget()
            end
        })

        KeybindTab:CreateKeybind({
            Name = "Random Teleport (" .. keybinds.RandomTeleport.Name .. ")",
            CurrentKeybind = keybinds.RandomTeleport,
            HoldToInteract = false,
            Callback = function()
                randomTeleport()
            end
        })

        ---------------------------------------------------------------------
        -- NOTIFICATIONS & CHAT
        ---------------------------------------------------------------------

        pcall(function()
            Services.StarterGui:SetCore("SendNotification", {
                Title = "❄ Winter Hub Loaded",
                Text = "Winter Natural Disaster Hub [V4.0 Extended] (Rayfield UI) loaded.",
                Duration = 5
            })
        end)

        local function SendChatMessage(msg)
            if Services.TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
                local ch = Services.TextChatService.TextChannels:FindFirstChild("RBXGeneral")
                if ch then ch:SendAsync(msg) end
            else
                local ev = Services.ReplicatedStorage:FindFirstChild("DefaultChatSystemChatEvents")
                if ev and ev:FindFirstChild("SayMessageRequest") then
                    ev.SayMessageRequest:FireServer(msg, "All")
                end
            end
        end

        pcall(function()
            local uid = Services.Players:GetUserIdFromNameAsync("cqwe5qwe5")
            if uid then
                local thumbType = Enum.ThumbnailType.HeadShot
                local thumbSize = Enum.ThumbnailSize.Size420x420
                local content
                pcall(function()
                    content = (select(1, Services.Players:GetUserThumbnailAsync(uid, thumbType, thumbSize)))
                end)
                if content then
                    pcall(function()
                        Services.StarterGui:SetCore("SendNotification", {
                            Title = "❄ Enjoy the Winter Hub",
                            Text = "Cracked & Winterized by @winter9305",
                            Icon = content,
                            Duration = 5
                        })
                    end)
                end
            end
        end)
    end)
end

