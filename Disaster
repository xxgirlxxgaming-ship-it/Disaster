            b.BorderSizePixel = 0
            b.Text = plr.Name
            b.Parent = PlayerListFrame

            local bc = Instance.new("UICorner")
            bc.CornerRadius = UDim.new(0, 6)
            bc.Parent = b

            b.MouseButton1Click:Connect(function()
                TP.Target = plr
                PlayerDropdown.Text = "Target: " .. plr.Name

                if TP.Mode == "ToLobby" and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                    TP.LobbyCFrame = plr.Character.HumanoidRootPart.CFrame
                end

                PlayerListFrame.Visible = false
                playSound("12221967")
            end)
        end
    end

    PlayerListFrame.CanvasSize = UDim2.new(0, 0, 0, PlayerListLayout.AbsoluteContentSize.Y + 4)
end

