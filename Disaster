        local TP = {
            Mode        = "ToPlayer",  -- "ToPlayer", "ToLobby", "Smooth"
            Target      = nil,
            LobbyCFrame = nil,
            InProgress  = false,
            SafeRadius  = 3,
            SideOffset  = 1.5,
            AutoFollow  = false,
            Orbit       = false,
            StayAbove   = false
        }

        local function notify(title, text, duration)
