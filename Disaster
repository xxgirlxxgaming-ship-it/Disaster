-- GLOBAL INPUT HANDLER (KEYBINDS)
---------------------------------------------------------------------

Services.UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.UserInputType ~= Enum.UserInputType.Keyboard then return end

    local key = input.KeyCode

    if key == keybinds.RingParts then
        toggleRing()

    elseif key == keybinds.Flight then
        if Movement.Flying then
            stopFlight()
        else
            startFlight()
        end

    elseif key == keybinds.Godmode then
        toggleGod()

    elseif key == keybinds.Menu then
        Rayfield:Toggle()
        playSound("12221967")

    elseif key == keybinds.Noclip then
        toggleNoclip()

    elseif key == keybinds.Teleport then
        teleportToTarget()

    elseif key == keybinds.RandomTeleport then
        randomTeleport()
    end
end)
