local Ring = {
    Radius         = 45,      -- default radius
    MinDist        = 6,
    Height         = 35,
    RotSpeed       = 4,
    Force          = 300,
    HeightOffset   = 5,
    Enabled        = false,
    Parts          = {},
    Speed          = 4,

    -- Ring modes
    Mode           = 1,
    MaxSpeed       = 450,

    -- Visual features
    ColorMode      = "Off", -- "Off", "Static", "Rainbow"
    StaticColor    = Color3.fromRGB(255, 255, 255),

    -- internal angle tracking
    AngleByPart    = {},
    AngleStep      = math.rad(4),

    -- smooth damping factors
    CloseDamp      = 0.25,
    FarBoost       = 1.1,
    BaseDamp       = 0.65
}

local function getRoot()
    local c = LocalPlayer.Character
    return c and c:FindFirstChild("HumanoidRootPart") or nil
end

local function retainRingPart(part)
    if part:IsA("BasePart") and not part.Anchored and part:IsDescendantOf(workspace) then
        if part.Parent == LocalPlayer.Character or part:IsDescendantOf(LocalPlayer.Character) then
            return false
        end
        part.CustomPhysicalProperties = PhysicalProperties.new(0, 0, 0, 0, 0)
        part.CanCollide = false
        return true
    end
    return false
end

local function assignAngleForPart(p)
    if Ring.AngleByPart[p] then return end
    local idx = #Ring.Parts + 1
    local angle = (idx - 1) * Ring.AngleStep
    Ring.AngleByPart[p] = angle
end

local function addRingPart(p)
    if retainRingPart(p) and not table.find(Ring.Parts, p) then
        table.insert(Ring.Parts, p)
        assignAngleForPart(p)
    end
end

local function removeRingPart(p)
    local i = table.find(Ring.Parts, p)
    if i then table.remove(Ring.Parts, i) end
    Ring.AngleByPart[p] = nil
end

for _, d in pairs(workspace:GetDescendants()) do
    addRingPart(d)
end
workspace.DescendantAdded:Connect(addRingPart)
workspace.DescendantRemoving:Connect(removeRingPart)

local function clampRingVelocity(part, rootPos)
    local rel = part.Position - rootPos
    if rel.Magnitude < Ring.MinDist + 2 then
        local v = part.Velocity
        part.Velocity = Vector3.new(v.X, math.clamp(v.Y, -30, 30), v.Z)
    end
end

local function getRingTargetPosition(mode, center, baseRadius)
    local t = time()

    if mode == 1 then
        return function(angle)
            local r = math.max(baseRadius, Ring.MinDist)
            local yWave = math.sin(t * 1.2) * (Ring.Height * 0.15)
            return Vector3.new(
                center.X + math.cos(angle) * r,
                center.Y + yWave,
                center.Z + math.sin(angle) * r
            )
        end

    elseif mode == 2 then
        return function(angle)
            local r = math.max(baseRadius * 0.9, Ring.MinDist)
            local height = math.sin(angle * 1.8 + t * 1.0) * (Ring.Height * 0.7)
            local spin = angle + t * 0.6
            return Vector3.new(
                center.X + math.cos(spin) * r,
                center.Y + height,
                center.Z + math.sin(spin) * r
            )
        end

    elseif mode == 3 then
        return function(angle)
            local r = baseRadius
            local vAngle = math.sin(angle * 1.7 + t * 0.5) * math.rad(65)
            local y = math.sin(vAngle) * r
            local flatR = math.cos(vAngle) * r
            local spin = angle * 1.05
            return Vector3.new(
                center.X + math.cos(spin) * flatR,
                center.Y + y,
                center.Z + math.sin(spin) * flatR
            )
        end

    elseif mode == 4 then
        return function(angle)
            local pulse = math.sin(t * 1.6) * 0.2 + 1.0
            local r = math.max(baseRadius * pulse, Ring.MinDist)
            local yWave = math.cos(angle * 1.3 + t * 0.9) * (Ring.Height * 0.2)
            return Vector3.new(
                center.X + math.cos(angle) * r,
                center.Y + yWave,
                center.Z + math.sin(angle) * r
            )
        end

    elseif mode == 5 then
        return function(angle)
            local r = math.max(baseRadius * 0.95, Ring.MinDist)
            local noiseX = math.noise(t * 0.5, angle) * 2
            local noiseZ = math.noise(t * 0.5, angle + 10) * 2
            local yWave = math.sin(t * 1.0) * (Ring.Height * 0.25)
            return Vector3.new(
                center.X + math.cos(angle) * r + noiseX,
                center.Y + yWave,
                center.Z + math.sin(angle) * r + noiseZ
            )
        end

    elseif mode == 6 then
        return function(angle)
            local r = math.max(baseRadius, Ring.MinDist)
            local waveX = math.sin(t * 1.0 + angle * 1.6) * 4
            local waveZ = math.cos(t * 1.0 + angle * 1.6) * 4
            local yWave = math.sin(t * 0.9 + angle) * (Ring.Height * 0.18)
            return Vector3.new(
                center.X + math.cos(angle) * r + waveX,
                center.Y + yWave,
                center.Z + math.sin(angle) * r + waveZ
            )
        end

    elseif mode == 7 then
        return function(angle)
            local r = math.max(baseRadius * 0.7, Ring.MinDist)
            local height = math.sin(angle * 1.6 + t * 1.2) * (Ring.Height * 0.5)
            local spiral = (math.sin(t * 1.3) + 1) * 0.5
            local twist = spiral * 3
            local spin = angle + twist
            return Vector3.new(
                center.X + math.cos(spin) * r,
                center.Y + height,
                center.Z + math.sin(spin) * r
            )
        end

    elseif mode == 8 then
        return function(angle)
            local r = math.max(baseRadius, Ring.MinDist)
            local upper = (math.sin(angle * 2 + t * 1.2) > 0) and 1 or -1
            local yAdd = (Ring.Height * 0.25) * upper
            local spin = angle * 1.15
            return Vector3.new(
                center.X + math.cos(spin) * r,
                center.Y + yAdd,
                center.Z + math.sin(spin) * r
            )
        end

    elseif mode == 9 then
        return function(angle)
            local wave = math.sin(t * 1.8 + angle * 2.6) * 0.25 + 1.0
            local r = math.max(baseRadius * wave, Ring.MinDist)
            local yWave = math.sin(t * 1.2 + angle * 1.3) * (Ring.Height * 0.3)
            return Vector3.new(
                center.X + math.cos(angle) * r,
                center.Y + yWave,
                center.Z + math.sin(angle) * r
            )
        end

    elseif mode == 10 then
        return function(angle)
            local twoPi = math.pi * 2
            local layer = math.floor(((angle % twoPi) / (math.pi / 3)))
            local rMult = 0.85 + layer * 0.1
            local r = math.max(baseRadius * rMult, Ring.MinDist)
            local yLayer = (-2 + layer) * (Ring.Height * 0.09)
            local jitterY = math.noise(t * 0.7, angle) * 1.5
            local spin = angle * 1.05
            return Vector3.new(
                center.X + math.cos(spin) * r,
                center.Y + yLayer + jitterY,
                center.Z + math.sin(spin) * r
            )
        end
    end

    return function(angle)
        local r = math.max(baseRadius, Ring.MinDist)
        local yWave = math.sin(t * 1.0) * (Ring.Height * 0.2)
        return Vector3.new(
            center.X + math.cos(angle) * r,
            center.Y + yWave,
            center.Z + math.sin(angle) * r
        )
    end
end

local function hsvToColor3(h, s, v)
    return Color3.fromHSV(h, s, v)
end

Services.RunService.Heartbeat:Connect(function()
    if not Ring.Enabled then return end
    local root = getRoot()
    if not root then return end

    local rootPos = root.Position
    local center = rootPos + Vector3.new(0, Ring.HeightOffset, 0)

    local targetFunc = getRingTargetPosition(Ring.Mode, center, Ring.Radius)

    local useColor = nil
    if Ring.ColorMode == "Rainbow" then
        local h = (tick() * 0.5) % 1
        useColor = hsvToColor3(h, 1, 1)
    elseif Ring.ColorMode == "Static" then
        useColor = Ring.StaticColor
    end

    local angleDelta = math.rad(Ring.Speed)

    for _, p in ipairs(Ring.Parts) do
        if p.Parent and not p.Anchored then
            local baseAngle = Ring.AngleByPart[p]
            if not baseAngle then
                assignAngleForPart(p)
                baseAngle = Ring.AngleByPart[p]
            end

            baseAngle = baseAngle + angleDelta
            Ring.AngleByPart[p] = baseAngle

            local targetPos = targetFunc(baseAngle)
            local dir = targetPos - p.Position
            local d = dir.Magnitude
            if d > 0 then
                local desiredVel = dir.Unit * Ring.Force

                if d < 10 then
                    desiredVel = desiredVel * Ring.CloseDamp
                elseif d > 60 then
                    desiredVel = desiredVel * Ring.FarBoost
                end

                if desiredVel.Magnitude > Ring.MaxSpeed then
                    desiredVel = desiredVel.Unit * Ring.MaxSpeed
                end

                local oldVel = p.Velocity
                local smoothFactor = Ring.BaseDamp
                local newVel = oldVel:Lerp(desiredVel, smoothFactor)

                p.Velocity = newVel
                clampRingVelocity(p, rootPos)
            end

            if useColor then
                p.Color = useColor
            end
        end
    end
end)

