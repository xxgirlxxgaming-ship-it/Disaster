        -- NEW ring position logic with fun modes
        local function computeRingTargetPos(center, part, t, idx)
            local mode = Ring.Mode
            local baseR = math.max(Ring.Radius, Ring.MinDist)

            -- stable seed for each part
            local index = idx or 1
            local seed = index * 17.37

            if mode == "Chaos" then
                local r = baseR * (0.5 + math.abs(math.sin(t * 1.5 + seed)) * 0.8)
                local yaw = t * 2 + seed
                local pitch = math.sin(t * 1.3 + seed) * math.rad(80)

                local x = math.cos(yaw) * math.cos(pitch)
                local y = math.sin(pitch)
                local z = math.sin(yaw) * math.cos(pitch)

                local dir = Vector3.new(x, y, z)
                local targetPos = center + dir.Unit * r
                targetPos += Vector3.new(
                    math.sin(t * 5 + seed) * 2,
                    math.cos(t * 4 + seed * 0.5) * 2,
                    math.sin(t * 3 - seed) * 2
                )
                return targetPos

            elseif mode == "Sphere" then
                local sphereR = baseR
                local angleA = t * 0.8 + seed
                local angleB = t * 1.1 - seed

                local x = math.cos(angleA) * math.sin(angleB)
                local y = math.cos(angleB)
                local z = math.sin(angleA) * math.sin(angleB)

                return center + Vector3.new(x, y, z) * sphereR

            elseif mode == "Vortex" then
                local r = baseR * 0.7
                local heightSpan = Ring.Height
                local verticalPhase = (math.sin(t * 0.8 + seed) + 1) * 0.5 -- 0..1
                local yOff = verticalPhase * heightSpan

                local swirlSpeed = 4 + verticalPhase * 6
                local angle = t * swirlSpeed + seed

                local x = math.cos(angle) * r * (0.3 + verticalPhase)
                local z = math.sin(angle) * r * (0.3 + verticalPhase)

                return center + Vector3.new(x, yOff, z)

            elseif mode == "Spiral" then
                local spiralR = baseR
                local angle = t * 3 + seed
                local yOff = math.sin(t * 1.5 + seed) * (Ring.Height * 0.7)

                local x = math.cos(angle) * spiralR
                local z = math.sin(angle) * spiralR

                return center + Vector3.new(x, yOff, z)

            elseif mode == "Orbit" then
                local orbitR = baseR
                local angle = t * (Ring.Speed * 0.15) + seed
                local wave = math.sin(t * 1.3 + seed) * 3

                local x = math.cos(angle) * orbitR
                local z = math.sin(angle) * orbitR

                return center + Vector3.new(x, wave, z)
            end

            -- fallback (basic ring)
            local angle = t * 2 + seed
            local x = math.cos(angle) * baseR
            local z = math.sin(angle) * baseR
            return center + Vector3.new(x, 0, z)
        end

