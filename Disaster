    if p ~= LocalPlayer then
        table.insert(playersNames, p.Name)
    end
end

local targetDropdown = TeleportTab:CreateDropdown({
    Name = "Select Target Player",
    Options = playersNames,
    CurrentOption = "",
    Callback = function(Option)
        local name = typeof(Option) == "table" and tostring(Option[1]) or tostring(Option)
        local plr = Services.Players:FindFirstChild(name)
        if plr then
            TP.Target = plr
            if TP.Mode == "ToLobby" and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                TP.LobbyCFrame = plr.Character.HumanoidRootPart.CFrame
            end
            playSound("12221967")
        end
    end
})

Services.Players.PlayerAdded:Connect(function(plr)
    if plr ~= LocalPlayer then
        table.insert(playersNames, plr.Name)
        targetDropdown:Refresh(playersNames, TP.Target and TP.Target.Name or "")
    end
end)

Services.Players.PlayerRemoving:Connect(function(plr)
    for i, n in ipairs(playersNames) do
        if n == plr.Name then
            table.remove(playersNames, i)
            break
        end
    end
    targetDropdown:Refresh(playersNames, TP.Target and TP.Target.Name or "")
end)

