        local function ensureTarget()
            if not TP.Target or not TP.Target.Parent then
                notify("Teleport", "No valid target selected.")
                return false
            end

            local char = TP.Target.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")

            if not char or not hrp then
                notify("Teleport", "Target has no character yet.")
                return false
            end

