local TP = {
    Mode        = "ToPlayer",
    Target      = nil,
    LobbyCFrame = nil,
    InProgress  = false,

    SafeRadius  = 3,
    SideOffset  = 1.5,
    AutoFollow  = false,
    Orbit       = false,
    StayAbove   = false
}

local function notify(title, text, duration)
    pcall(function()
        Services.StarterGui:SetCore("SendNotification", {
            Title = title or "Teleport",
            Text = text or "",
            Duration = duration or 3
        })
    end)
end

local function ensureTarget()
    if not TP.Target or not TP.Target.Parent then
        notify("Teleport", "No valid target selected.")
        return false
    end

    local char = TP.Target.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")

    if not char or not hrp then
        notify("Teleport", "Target has no character yet.")
        return false
    end

    return true
end

local function getValidRandomPlayer()
    local list = {}
    for _, plr in ipairs(Services.Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            table.insert(list, plr)
        end
    end
    if #list == 0 then return nil end
    return list[math.random(1, #list)]
end

local function safeTeleportCFrame(cf)
    local c = LocalPlayer.Character
    local r = c and c:FindFirstChild("HumanoidRootPart")
    if not r then
        notify("Teleport", "Your character is not loaded.")
        return
    end

    cf = cf + Vector3.new(0, 2.5, 0)

    setCharCollide(c, false)

    r.Velocity = Vector3.new()
    r.AssemblyLinearVelocity = Vector3.new()
    r.AssemblyAngularVelocity = Vector3.new()
    r.CFrame = cf

    task.delay(0.4, function()
        if c then setCharCollide(c, true) end
    end)
end

local function smoothTeleportTo(targetCF)
    if TP.InProgress then return end
    TP.InProgress = true

    local c = LocalPlayer.Character
    local r = c and c:FindFirstChild("HumanoidRootPart")
    if not r then
        TP.InProgress = false
        notify("Teleport", "Your character is not loaded.")
        return
    end

    local startCF = r.CFrame
    local steps, delayStep = 16, 0.02

    setCharCollide(c, false)

    for i = 1, steps do
        if not c or not r then break end

        local t = i / steps
        local alpha = t * t * (3 - 2 * t)

        local newCF = startCF:Lerp(targetCF, alpha)
        r.CFrame = newCF + Vector3.new(0, 2.5, 0)

        r.Velocity = Vector3.new()
        r.AssemblyLinearVelocity = Vector3.new()
        r.AssemblyAngularVelocity = Vector3.new()

        task.wait(delayStep)
    end

    task.delay(0.3, function()
        if c then setCharCollide(c, true) end
    end)

    TP.InProgress = false
end

local function getSafeTargetCF(targetRef, fromPos)
    local targetCFrame

    if typeof(targetRef) == "Instance" and targetRef:IsA("BasePart") then
        targetCFrame = targetRef.CFrame
    elseif typeof(targetRef) == "CFrame" then
        targetCFrame = targetRef
    else
        return nil
    end

    local targetPos = targetCFrame.Position
    fromPos = fromPos or targetPos

    local baseDist = (fromPos - targetPos).Magnitude

    local backOffset = TP.SafeRadius
    if baseDist < 8 then
        backOffset = math.max(2, TP.SafeRadius - 1)
    elseif baseDist > 80 then
        backOffset = TP.SafeRadius + 2
    end

    local cf = targetCFrame * CFrame.new(0, 0, -backOffset)

    local sideSign = (math.random(0, 1) == 0) and -1 or 1
    local sideOffset = TP.SideOffset * sideSign
    cf = cf * CFrame.new(sideOffset, 0, 0)

    if TP.StayAbove then
        cf = cf * CFrame.new(0, 2, 0)
    end

    return cf
end

local function teleportToTarget()
    local c = LocalPlayer.Character
    local r = c and c:FindFirstChild("HumanoidRootPart")
    if not r then
        notify("Teleport", "Your character is not loaded.")
        return
    end

    if not ensureTarget() then
        return
    end

    if TP.Mode == "ToLobby" then
        local targetChar = TP.Target.Character
        local targetRoot = targetChar and targetChar:FindFirstChild("HumanoidRootPart")

        local lobbyCF = TP.LobbyCFrame
        if not lobbyCF and targetRoot then
            lobbyCF = targetRoot.CFrame
        end

        if lobbyCF then
            lobbyCF = lobbyCF * CFrame.new(0, 3, 0)
            safeTeleportCFrame(lobbyCF)
            playSound("12221967")
            notify("Teleport", "Teleported to lobby position.")
        else
            notify("Teleport", "Could not find a lobby position.")
        end
        return
    end

    local tChar = TP.Target.Character
    local tr = tChar and tChar:FindFirstChild("HumanoidRootPart")
    if not tr then
        notify("Teleport", "Target lost or not spawned.")
        return
    end

    local targetCF = getSafeTargetCF(tr, r.Position)
    if not targetCF then
        notify("Teleport", "Failed to compute target position.")
        return
    end

    if TP.Mode == "Smooth" then
        smoothTeleportTo(targetCF)
    else
        safeTeleportCFrame(targetCF)
    end

    playSound("12221967")
    notify("Teleport", "Teleported to " .. TP.Target.Name .. ".")
end

local function randomTeleport()
    local plr = getValidRandomPlayer()
    if not plr then
        notify("Teleport", "No other players to teleport to.")
        return
    end

    TP.Target = plr

    local tChar = plr.Character
    local tr = tChar and tChar:FindFirstChild("HumanoidRootPart")
    if not tr then
        notify("Teleport", "Target has no character.")
        return
    end

    if TP.Mode == "ToLobby" then
        local lobbyCF = tr.CFrame * CFrame.new(0, 3, 0)
        safeTeleportCFrame(lobbyCF)
        playSound("12221967")
        notify("Teleport", "Teleported to random player's lobby position.")
        return
    end

    local fromRoot = (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart"))
    local fromPos = fromRoot and fromRoot.Position or tr.Position

    local cf = getSafeTargetCF(tr, fromPos)
    if not cf then
        notify("Teleport", "Failed to compute random target position.")
        return
    end

    if TP.Mode == "Smooth" then
        smoothTeleportTo(cf)
    else
        safeTeleportCFrame(cf)
    end

    playSound("12221967")
    notify("Teleport", "Random teleport to " .. plr.Name .. ".")
end

Services.RunService.Heartbeat:Connect(function(dt)
    if not TP.AutoFollow or not TP.Target then return end

    local c = LocalPlayer.Character
    local r = c and c:FindFirstChild("HumanoidRootPart")
    local tChar = TP.Target.Character
    local tr = tChar and tChar:FindFirstChild("HumanoidRootPart")
    if not r or not tr then return end

    local fromPos = r.Position
    local baseCF = tr.CFrame

    if TP.Orbit then
        local angle = tick() * 0.8
        local orbitRadius = math.max(TP.SafeRadius, 4)
        local ofs = Vector3.new(math.cos(angle) * orbitRadius, 0, math.sin(angle) * orbitRadius)
        baseCF = CFrame.new(tr.Position + ofs, tr.Position)
    end

    local desiredCF = getSafeTargetCF(baseCF, fromPos)
    if not desiredCF then return end

    if TP.Mode == "Smooth" then
        local alpha = math.clamp(dt * 4, 0, 1)
        local blended = r.CFrame:Lerp(desiredCF, alpha)
        r.CFrame = blended
    else
        r.CFrame = desiredCF
    end
end)

