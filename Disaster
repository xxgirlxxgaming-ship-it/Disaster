    page.Parent = ContentFrame
    return page
end

local function setActiveTab(tabName)
    for name, data in pairs(Tabs) do
        local selected = (name == tabName)
        data.Page.Visible = selected
        data.Button.BackgroundColor3 = selected and Color3.fromRGB(90, 130, 190) or Color3.fromRGB(30, 46, 76)
        data.Button.TextColor3 = selected and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(210, 225, 245)
    end
    playSound("12221967")
end


