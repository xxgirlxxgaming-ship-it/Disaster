            healthLabel.Text = ""
        end

        nameLabel.Visible = MiscState.ESPNameDist

        local col = getTeamColorForPlayer(plr)
        stroke.Color = col
        boxAdornment.Color3 = col
        tracer.BackgroundColor3 = col

